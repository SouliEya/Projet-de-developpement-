# Backend Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/smart-test-assistant
# Pour MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart-test-assistant

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Frontend Configuration (si nécessaire)
REACT_APP_API_URL=http://localhost:5000/api

# AI Service Configuration
OPENAI_API_KEY=your_openai_api_key_here
# Obtenir une clé sur: https://platform.openai.com/api-keys

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Email Configuration (optionnel, pour notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
